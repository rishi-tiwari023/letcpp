    <main>
        <h1>LeetCode 874: Walking Robot Simulation (C++)</h1>
        <div class="problem-description">
            <p><strong>Problem:</strong>
                A robot is placed at the origin (0, 0) facing north. It receives a list of commands where positive integers represent steps to move forward, -1 represents turning right 90 degrees, and -2 represents turning left 90 degrees. There are also obstacles at certain coordinates that block the robot's path. Return the square of the maximum Euclidean distance the robot reaches at any point during its journey.
            </p>
            <p><strong>Example:</strong>
                Input: commands = [4,-1,3], obstacles = []<br>
                Output: 25<br>
                Explanation: The robot moves 4 steps north to (0,4), turns right, moves 3 steps east to (3,4). The maximum distance squared is 3² + 4² = 25.
            </p>
        </div>
        <div class="code-container">
            <button class="copy-button" onclick="copyCode(this)">Copy Code</button>
            <pre><code class="language-cpp">class Solution {
public:
    int robotSim(vector&lt;int&gt;&amp; cmds, vector&lt;vector&lt;int&gt;&gt;&amp; obsList) {
        unordered_set&lt;string&gt; obstacleSet;
        for(auto &amp;o : obsList){
            obstacleSet.insert(to_string(o[0]) + "#" + to_string(o[1]));
        }
        int dx[4] = {0, 1, 0, -1};
        int dy[4] = {1, 0, -1, 0};
        int x = 0, y = 0;
        int dirIdx = 0;
        int maxDist = 0;
        for(int cmd : cmds){
            if(cmd == -1){
                dirIdx = (dirIdx + 1) % 4;
            }
            else if(cmd == -2){
                dirIdx = (dirIdx + 3) % 4;
            }
            else{
                // simulate movement step-by-step
                for(int step = 0; step &lt; cmd; step++){
                    int nextX = x + dx[dirIdx];
                    int nextY = y + dy[dirIdx];
                    string key = to_string(nextX) + "#" + to_string(nextY);
                    if(obstacleSet.count(key)) break;
                    x = nextX;
                    y = nextY;
                    maxDist = max(maxDist, x*x + y*y);
                }
            }
        }
        return maxDist;
    }
};</code></pre>
