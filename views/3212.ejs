    <main>
        <h1>LeetCode 3212: Count Submatrices With Equal Frequency of X and Y (C++)</h1>
        <div class="problem-description">
            <p><strong>Problem:</strong>
                Given an m x n matrix containing only 'X' and 'Y', count the number of submatrices where the frequency
                of 'X' equals the frequency of 'Y'. A submatrix is defined by a top-left corner and a bottom-right
                corner.
            </p>
            <p><strong>Example:</strong>
                Input: matrix = [["X","Y","Y"],["Y","X","Y"],["X","Y","X"]]<br>
                Output: 5<br>
                Explanation: The valid submatrices with equal count of X and Y are counted.
            </p>
        </div>
        <div class="code-container">
            <button class="copy-button" onclick="copyCode(this)">Copy Code</button>
            <pre><code class="language-cpp">class Solution {
public:
    int numberOfSubmatrices(vector&lt;vector&lt;char&gt;&gt;&amp; matrix) {
        int rowCount = matrix.size();
        int colCount = matrix[0].size();
        vector&lt;int&gt; prefixX(colCount, 0);
        vector&lt;int&gt; prefixY(colCount, 0);
        int validCount = 0;
        for (int row = 0; row &lt; rowCount; row++) {
            int currentX = 0, currentY = 0;
            for (int col = 0; col &lt; colCount; col++) {
                if (matrix[row][col] == 'X')
                    currentX++;
                else if (matrix[row][col] == 'Y')
                    currentY++;
                prefixX[col] += currentX;
                prefixY[col] += currentY;
                // Equal X and Y with at least one valid character
                if (prefixX[col] == prefixY[col] &amp;&amp; prefixX[col] &gt; 0)
                    validCount++;
            }
        }
        return validCount;
    }
};</code></pre>
