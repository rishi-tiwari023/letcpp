        <h1>LeetCode 2574: Left and Right Sum Differences (C++)</h1>
        <div class="problem-description">
            <p><strong>Problem:</strong>
                Given a 0-indexed integer array arr, compute an array result where result[i] is the absolute difference
                between the sum of elements to the left of index i in arr and the sum of elements to the right of index
                i in arr.
            </p>
            <p><strong>Example:</strong>
                Input: arr = [10,4,8,3]<br>
                Output: [15,1,11,22]<br>
                Explanation: For index 0: left sum = 0, right sum = 4+8+3 = 15, difference = 15. For index 1: left sum =
                10, right sum = 8+3 = 11, difference = 1. For index 2: left sum = 10+4 = 14, right sum = 3, difference =
                11. For index 3: left sum = 10+4+8 = 22, right sum = 0, difference = 22.
            </p>
        </div>
        <div class="code-container">
            <button class="copy-button" onclick="copyCode(this)">Copy Code</button>
            <pre><code class="language-cpp">class Solution {
public:
    vector&lt;int&gt; leftRightDifference(vector&lt;int&gt;&amp; arr) {
        int len = arr.size();
        int right = 0;
        for (int x : arr)
            right += x;
        int left = 0;
        vector&lt;int&gt; res(len);
        for (int i = 0; i &lt; len; i++) {
            right -= arr[i]; // current element moves out of right sum
            res[i] = abs(left - right);
            left += arr[i];
        }
        return res;
    }
};</code></pre>
