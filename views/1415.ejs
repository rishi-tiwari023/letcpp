        <h1>LeetCode 1415: The k-th Lexicographical String of All Happy Strings of Length n (C++)</h1>
        <div class="problem-description">
            <p><strong>Problem:</strong>
                A happy string is a string that consists only of letters from the set ['a', 'b', 'c'] and does not have
                any two consecutive characters that are the same. Given two integers n and k, return the kth string in
                lexicographical order among all happy strings of length n. If there are fewer than k happy strings of
                length n, return an empty string.
            </p>
            <p><strong>Example:</strong>
                Input: n = 3, k = 9<br>
                Output: "cab"<br>
                Explanation: There are 12 happy strings of length 3: "aba", "abc", "aca", "acb", "bab", "bac", "bca",
                "bcb", "cab", "cac", "cba", "cbc". The 9th one is "cab".
            </p>
        </div>
        <div class="code-container">
            <button class="copy-button" onclick="copyCode(this)">Copy Code</button>
            <pre><code class="language-cpp">class Solution {
public:
    string answer = "";
    int formed = 0;
    void build(int len, int target, string &amp;path) {
        if (!answer.empty()) return;   // Stop once kth string is found
        if (path.size() == len) {
            formed++;
            if (formed == target) answer = path;
            return;
        }
        for (char ch : {'a', 'b', 'c'}) {
            if (!path.empty() &amp;&amp; path.back() == ch) continue;
            path.push_back(ch);
            build(len, target, path);
            path.pop_back();
        }
    }
    string getHappyString(int n, int k) {
        string path = "";
        build(n, k, path);
        return answer;
    }
};</code></pre>
