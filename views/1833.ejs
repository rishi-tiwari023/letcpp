    <main>
        <h1>LeetCode 1833: Maximum Ice Cream Bars (C++)</h1>
        <div class="problem-description">
            <p><strong>Problem:</strong>
                You are given an array prices where prices[i] is the price of the i-th ice cream bar. You have a budget
                coins. Return the maximum number of ice cream bars you can buy with your budget. Note that you can buy
                ice cream bars in any order.
            </p>
            <p><strong>Example:</strong>
                Input: prices = [1,3,2,4,1], budget = 7<br>
                Output: 4<br>
                Explanation: Buy the two bars with price 1 (spend 2), then buy the bar with price 2 (spend 2), then buy
                the bar with price 3 (spend 3). Total spent = 7, total bars = 4.
            </p>
        </div>
        <div class="code-container">
            <button class="copy-button" onclick="copyCode(this)">Copy Code</button>
            <pre><code class="language-cpp">class Solution {
public:
    int maxIceCream(vector&lt;int&gt;&amp; prices, int budget) {
        int highestPrice = *max_element(prices.begin(), prices.end());
        vector&lt;int&gt; count(highestPrice + 1, 0);
        for (int price : prices) {
            count[price]++;
        }
        int bars = 0;
        for (int price = 1; price &lt;= highestPrice; price++) {
            if (count[price] == 0)
                continue;
            // Buy as many bars as possible at this price
            int take = min(count[price], budget / price);
            bars += take;
            budget -= take * price;
            if (budget &lt; price)
                break;
        }
        return bars;
    }
};</code></pre>
