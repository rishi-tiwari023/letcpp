        <h1>LeetCode 3660: Jump Game IX (C++)</h1>
        <div class="problem-description">
            <p><strong>Problem:</strong>
                You are given an array arr of integers. Starting from index 0, you can jump to any index i where arr[i]
                is less than the maximum value seen so far up to the current index. For each position, determine the
                maximum value you can reach if you make optimal jumps from that position onward.
            </p>
            <p><strong>Example:</strong>
                Input: arr = [2,3,1,4,5]<br>
                Output: [5,4,4,5,5]<br>
                Explanation: From each index, the maximum reachable value considering jump constraints is computed based
                on the optimal path forward.
            </p>
        </div>
        <div class="code-container">
            <button class="copy-button" onclick="copyCode(this)">Copy Code</button>
            <pre><code class="language-cpp">class Solution {
public:
    vector&lt;int&gt; maxValue(vector&lt;int&gt;&amp; arr) {
        int len = arr.size();
        vector&lt;int&gt; leftMax(len), res(len);
        leftMax[0] = arr[0];
        // Store maximum value seen till each index
        for (int i = 1; i &lt; len; i++) {
            leftMax[i] = max(leftMax[i - 1], arr[i]);
        }
        int rightMin = INT_MAX;
        for (int i = len - 1; i &gt;= 0; i--) {
            // If a smaller value exists ahead, inherit next answer
            if (leftMax[i] &gt; rightMin) {
                res[i] = res[i + 1];
            } else {
                res[i] = leftMax[i];
            }
            rightMin = min(rightMin, arr[i]);
        }
        return res;
    }
};</code></pre>
