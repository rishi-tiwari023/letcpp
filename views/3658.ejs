        <h1>LeetCode 3658: GCD of Odd and Even Sums (C++)</h1>
        <div class="problem-description">
            <p><strong>Problem:</strong>
                Given a positive integer n, compute the sum of all odd numbers from 1 to 2n-1 and the sum of all even
                numbers from 2 to 2n. Return the GCD of these two sums.
            </p>
            <p><strong>Example:</strong>
                Input: value = 3<br>
                Output: 3<br>
                Explanation: Odd numbers up to 2*3-1=5: 1+3+5=9 = 3^2. Even numbers up to 2*3=6: 2+4+6=12 = 3*(3+1).
                GCD(9,12) = 3.
            </p>
        </div>
        <div class="code-container">
            <button class="copy-button" onclick="copyCode(this)">Copy Code</button>
            <pre><code class="language-cpp">class Solution {
public:
    int findGcd(int first, int second) {
        // Euclidean algorithm to compute GCD efficiently.
        if (second == 0)
            return first;
        return findGcd(second, first % second);
    }
    int gcdOfOddEvenSums(int value) {
        int oddTotal = value * value;
        int evenTotal = value * (value + 1);
        return findGcd(oddTotal, evenTotal);
    }
};</code></pre>
