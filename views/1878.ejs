<body>
    <main>
        <h1>LeetCode 1878: Get Biggest Three Rhombus Sums in a Grid (C++)</h1>
        <div class="problem-description">
            <p><strong>Problem:</strong>
                You are given an m x n integer matrix grid. A rhombus sum is the sum of the elements that form the
                border of a regular rhombus shape in grid. The rhombus must have the shape of a square rotated 45
                degrees with each of the corners centered in a grid cell. Return an array of the three largest distinct
                rhombus sums in the grid in descending order. If there are less than three distinct values, return all
                of them.
            </p>
            <p><strong>Example:</strong>
                Input: grid = [[3,4,5,1,3],[3,3,4,2,3],[20,30,200,40,10],[1,5,5,4,1],[4,3,2,2,5]]<br>
                Output: [228,216,211]<br>
                Explanation: The largest rhombus sums are 228, 216, and 211 from various rhombus shapes in the grid.
            </p>
        </div>
        <div class="code-container">
            <button class="copy-button" onclick="copyCode(this)">Copy Code</button>
            <pre><code class="language-cpp">class Solution {
public:
    vector&lt;int&gt; getBiggestThree(vector&lt;vector&lt;int&gt;&gt;&amp; g) {
        
        vector&lt;int&gt; ans;
        priority_queue&lt;int&gt; pq;
        
        int n = g.size();
        int m = g[0].size();
        
        // Single cells are also valid rhombuses
        for (int i = 0; i &lt; n; i++) {
            for (int j = 0; j &lt; m; j++) {
                pq.push(g[i][j]);
            }
        }
        
        int k = 1;
        int len = 2 * k + 1;
        
        while (len &lt;= n &amp;&amp; len &lt;= m) {
            
            for (int i = 0; i + len &lt;= n; i++) {
                for (int j = k; j &lt; m - k; j++) {
                    
                    int sum = g[i][j];
                    
                    for (int x = 1; x &lt;= k; x++) sum += g[i + x][j - x];
                    for (int x = 1; x &lt;= k; x++) sum += g[i + x][j + x];
                    
                    int b = i + len - 1;
                    
                    for (int x = 1; x &lt; k; x++) sum += g[b - x][j - x];
                    for (int x = 1; x &lt; k; x++) sum += g[b - x][j + x];
                    
                    sum += g[b][j];
                    
                    // Collect every rhombus boundary sum
                    pq.push(sum);
                }
            }
            
            k++;
            len = 2 * k + 1;
        }
        
        unordered_set&lt;int&gt; st;
        
        while (!pq.empty() &amp;&amp; st.size() &lt; 3) {
            st.insert(pq.top());
            pq.pop();
        }
        
        for (int x : st) ans.push_back(x);
        
        // Final answer must be in descending order
        sort(ans.begin(), ans.end(), greater&lt;int&gt;());
        
        return ans;
    }
};</code></pre>
