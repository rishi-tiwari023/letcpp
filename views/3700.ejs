    <main>
        <h1>LeetCode 3700: Number of ZigZag Arrays II (C++)</h1>
        <div class="problem-description">
            <p><strong>Problem:</strong>
                You are given three integers n, l, and r. Count the number of zigzag arrays of length n where each
                element is in the range [l, r]. A zigzag array strictly alternates between increasing and decreasing
                consecutive elements. Return the count modulo 10^9 + 7.
            </p>
            <p><strong>Example:</strong>
                Input: n = 3, l = 1, r = 3<br>
                Output: 12<br>
                Explanation: Valid zigzag arrays of length 3 from [1,3] either go up-then-down or down-then-up strictly.
                For example [1,3,2], [2,3,1], [1,2] etc. Count all valid such arrays modulo 10^9+7.
            </p>
        </div>
        <div class="code-container">
            <button class="copy-button" onclick="copyCode(this)">Copy Code</button>
            <pre><code class="language-cpp">using MatrixRow = vector&lt;long long&gt;;
using Matrix = vector&lt;MatrixRow&gt;;
using Memo = unordered_map&lt;int, Matrix&gt;;
const int MOD = 1e9 + 7;
class Solution {
    Matrix&amp; buildDP(Memo&amp; memo, int len, int states) {
        auto it = memo.find(len);
        if (it != memo.end()) {
            return it-&gt;second;
        }
        int leftLen = (len - 1) / 2 + 1;
        int rightLen = len - leftLen + 1;
        bool flipOrder = leftLen % 2;
        memo[len] = Matrix(states, MatrixRow(states, 0));
        Matrix&amp; curr = memo[len];
        Matrix&amp; leftPart = buildDP(memo, leftLen, states);
        Matrix&amp; rightPart = buildDP(memo, rightLen, states);
        for (int start = 0; start &lt; states; start++) {
            for (int end = 0; end &lt; states; end++) {
                for (int mid = 0; mid &lt; states; mid++) {
                    curr[start][end] +=
                        leftPart[start][mid] *
                        (flipOrder
                             ? rightPart[mid][end]
                             : rightPart[states - 1 - mid][states - 1 - end]);
                    if (curr[start][end] &gt; MOD) {
                        curr[start][end] %= MOD;
                    }
                }
            }
        }
        return curr;
    }
public:
    int zigZagArrays(int n, int l, int r) {
        long long ans = 0;
        int states = r - l + 1;
        Memo memo;
        // Base case for arrays of length 2
        memo[2] = Matrix(states, MatrixRow(states, 0));
        for (int start = 0; start &lt; states; start++) {
            for (int end = start + 1; end &lt; states; end++) {
                memo[2][start][end] = 1;
            }
        }
        Matrix&amp; finalDp = buildDP(memo, n, states);
        for (int start = 0; start &lt; states; start++) {
            for (int end = 0; end &lt; states; end++) {
                ans += finalDp[start][end];
            }
        }
        return ((ans * 2) % MOD + MOD) % MOD;
    }
};</code></pre>
