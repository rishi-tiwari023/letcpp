    <main>
        <h1>LeetCode 3600: Maximize Spanning Tree Stability with Upgrades (C++)</h1>
        <div class="problem-description">
            <p><strong>Problem:</strong>
                You are given an integer n representing n nodes labeled from 0 to n - 1, a 2D integer array edges where
                edges[i] = [ui, vi, stabilityi, mandatoryi] indicates an edge between nodes ui and vi with stability
                stabilityi. If mandatoryi = 1, the edge must be included in the spanning tree. You can upgrade at most k
                non-mandatory edges to double their stability. Return the maximum minimum stability among all edges in
                the spanning tree, or -1 if no valid spanning tree exists.
            </p>
            <p><strong>Example:</strong>
                Input: n = 4, edges = [[0,1,3,1],[1,2,5,0],[2,3,2,0],[0,3,4,0]], k = 1<br>
                Output: 4<br>
                Explanation: Include mandatory edge [0,1] with stability 3. Build spanning tree using other edges,
                upgrade the weakest, and maximize minimum stability to 4.
            </p>
        </div>
        <div class="code-container">
            <button class="copy-button" onclick="copyCode(this)">Copy Code</button>
            <pre><code class="language-cpp">class Solution {
public:
    class DSU {
    public:
        vector&lt;int&gt; parent, size;
        DSU(int n) {
            parent.resize(n);
            size.assign(n, 1);
            for (int i = 0; i &lt; n; i++) {
                parent[i] = i;
            }
        }
        int findParent(int node) {
            if (parent[node] == node) {
                return node;
            }
            return parent[node] = findParent(parent[node]);
        }
        bool unite(int u, int v) {
            u = findParent(u);
            v = findParent(v);
            if (u == v) {
                return false;
            }
            if (size[u] &lt; size[v]) {
                swap(u, v);
            }
            parent[v] = u;
            size[u] += size[v];
            return true;
        }
    };
    int maxStability(int n, vector&lt;vector&lt;int&gt;&gt;&amp; edges, int k) {
        DSU dsu(n);
        vector&lt;vector&lt;int&gt;&gt; optionalEdges;
        vector&lt;int&gt; selected;
        int components = n;
        int minMandatory = INT_MAX;
        // Mandatory edges must always be included
        for (auto &amp;edge : edges) {
            int u = edge[0];
            int v = edge[1];
            int stability = edge[2];
            int mandatory = edge[3];
            if (mandatory == 1) {
                if (!dsu.unite(u, v)) {
                    return -1;
                }
                components--;
                minMandatory = min(minMandatory, stability);
            } 
            else {
                optionalEdges.push_back(edge);
            }
        }
        if (components == 1) {
            return minMandatory;
        }
        sort(optionalEdges.begin(), optionalEdges.end(), [&amp;](auto &amp;a, auto &amp;b) {
            return a[2] &gt; b[2];
        });
        // Build strongest possible spanning tree greedily
        for (auto &amp;edge : optionalEdges) {
            int u = edge[0];
            int v = edge[1];
            int stability = edge[2];
            if (dsu.unite(u, v)) {
                selected.push_back(stability);
                components--;
                if (components == 1) {
                    break;
                }
            }
        }
        if (components &gt; 1) {
            return -1;
        }
        sort(selected.begin(), selected.end());
        // Upgrade weakest chosen edges first
        for (int i = 0; i &lt; min(k, (int)selected.size()); i++) {
            selected[i] *= 2;
        }
        int weakest = *min_element(selected.begin(), selected.end());
        if (minMandatory == INT_MAX) {
            return weakest;
        }
        return min(minMandatory, weakest);
    }
};</code></pre>
