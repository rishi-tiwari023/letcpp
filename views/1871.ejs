    <main>
        <h1>LeetCode 1871: Jump Game VII (C++)</h1>
        <div class="problem-description">
            <p><strong>Problem:</strong>
                You are given a binary string s and two integers minJump and maxJump. In one move, you can jump from
                index i to any index j such that i + minJump &lt;= j &lt;= i + maxJump and s[j] = '0'. Find if you can
                reach the last index of s.
            </p>
            <p><strong>Example:</strong>
                Input: s = "011010", minJump = 2, maxJump = 3<br>
                Output: true<br>
                Explanation: You can jump from index 0 to index 3 (distance 3, s[3]='0'). Then jump from index 3 to
                index 5 (distance 2, s[5]='0').
            </p>
        </div>
        <div class="code-container">
            <button class="copy-button" onclick="copyCode(this)">Copy Code</button>
            <pre><code class="language-cpp">class Solution {
public:
    bool canReach(string str, int mn, int mx) {
        int len = str.size();
        queue&lt;int&gt; que;
        que.push(0);
        int far = 1;
        while (!que.empty()) {
            int pos = que.front();
            que.pop();
            if (pos == len - 1) {
                return true;
            }
            int left = max(pos + mn, far);
            int right = min(pos + mx, len - 1);
            // Push all reachable unprocessed indices
            for (int i = left; i &lt;= right; i++) {
                if (str[i] == '0') {
                    que.push(i);
                }
            }
            // Track farthest processed boundary
            far = max(far, pos + mx + 1);
        }
        return false;
    }
};</code></pre>
