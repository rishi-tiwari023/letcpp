    <main>
        <h1>LeetCode 3567: Minimum Absolute Difference in Sliding Submatrix (C++)</h1>
        <div class="problem-description">
            <p><strong>Problem:</strong>
                You are given an m x n matrix arr and an integer k. For each k x k submatrix, find the minimum absolute
                difference between any two distinct elements in that submatrix. Return a matrix of size (m - k + 1) x (n
                - k + 1) containing these minimum differences.
            </p>
            <p><strong>Example:</strong>
                Input: arr = [[1,2,3],[4,5,6],[7,8,9]], k = 2<br>
                Output: [[1,1],[1,1]]<br>
                Explanation: For each 2x2 submatrix, we compute the minimum absolute difference between any two distinct
                elements.
            </p>
        </div>
        <div class="code-container">
            <button class="copy-button" onclick="copyCode(this)">Copy Code</button>
            <pre><code class="language-cpp">class Solution {
public:
    vector&lt;vector&lt;int&gt;&gt; minAbsDiff(vector&lt;vector&lt;int&gt;&gt;&amp; arr, int sizeK) {
        int nRows = arr.size(), nCols = arr[0].size();
        vector&lt;vector&lt;int&gt;&gt; output(nRows - sizeK + 1, vector&lt;int&gt;(nCols - sizeK + 1));
        for (int sr = 0; sr &lt;= nRows - sizeK; sr++) {
            for (int sc = 0; sc &lt;= nCols - sizeK; sc++) {
                vector&lt;int&gt; temp;
                for (int i = sr; i &lt; sr + sizeK; i++)
                    for (int j = sc; j &lt; sc + sizeK; j++)
                        temp.push_back(arr[i][j]);
                sort(temp.begin(), temp.end());
                int minVal = INT_MAX;
                // compute min diff between distinct neighbors
                for (int i = 1; i &lt; temp.size(); i++) {
                    if (temp[i] == temp[i - 1]) continue;
                    minVal = min(minVal, temp[i] - temp[i - 1]);
                }
                if (minVal != INT_MAX)
                    output[sr][sc] = minVal;
                else
                    output[sr][sc] = 0;
            }
        }
        return output;
    }
};</code></pre>
