    <main>
        <h1>LeetCode 1356: Sort Integers by The Number of 1 Bits (C++)</h1>
        <div class="problem-description">
            <p><strong>Problem:</strong>
                You are given an integer array arr. Sort the integers in the array in ascending order by the number of
                1's in their binary representation and in case of two or more integers have the same number of 1's, you
                have to sort them in ascending order by their value. Return the array after sorting it.
            </p>
            <p><strong>Example:</strong>
                Input: arr = [0,1,2,3,4,5,6,7,8]<br>
                Output: [0,1,2,4,8,3,5,6,7]<br>
                Explanation: [0] has 0 ones, [1,2,4,8] have 1 one, [3,5,6] have 2 ones, [7] has 3 ones. Sorted by count,
                then by value.
            </p>
        </div>
        <div class="code-container">
            <button class="copy-button" onclick="copyCode(this)">Copy Code</button>
            <pre><code class="language-cpp">class Solution {
public:
    vector&lt;int&gt; sortByBits(vector&lt;int&gt;&amp; v) {
        sort(v.begin(), v.end(), [&amp;](int x, int y) {
            int c1 = cnt(x);
            int c2 = cnt(y);
            
            if (c1 == c2)
                return x &lt; y;
            return c1 &lt; c2;  // compare based on set bits count
        });
        
        return v;
    }
    int cnt(int n) {
        int c = 0;
        while (n) {
            n = n &amp; (n - 1);  // removes lowest set bit
            c++;
        }
        return c;
    }
};</code></pre>
