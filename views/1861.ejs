        <h1>LeetCode 1861: Rotating the Box (C++)</h1>
        <div class="problem-description">
            <p><strong>Problem:</strong>
                You are given an m x n matrix box where each cell contains '#' (a stone), '*' (a fixed obstacle), or '.'
                (empty). Due to gravity, stones fall to the right within each row until they hit an obstacle or another
                stone. After applying gravity, rotate the box 90 degrees clockwise. Return the resulting matrix.
            </p>
            <p><strong>Example:</strong>
                Input: box = [["#",".","#"]]<br>
                Output: [["."],["#"],["#"]]<br>
                Explanation: After gravity, the box becomes [[".",".","#"]] (stones fall right). After 90-degree
                rotation, the result is [["."],["#"],["#"]].
            </p>
        </div>
        <div class="code-container">
            <button class="copy-button" onclick="copyCode(this)">Copy Code</button>
            <pre><code class="language-cpp">class Solution {
public:
    vector&lt;vector&lt;char&gt;&gt; rotateTheBox(vector&lt;vector&lt;char&gt;&gt;&amp; box) {
        int n = box.size();
        int m = box[0].size();
        for (int i = 0; i &lt; n; i++) {
            int idx = 0;
            for (int j = 0; j &lt; m; j++) {
                // Shift empty cells towards the left side
                if (box[i][j] == '.') {
                    swap(box[i][j], box[i][idx]);
                    idx++;
                }
                else if (box[i][j] == '*') {
                    idx = j + 1;
                }
            }
        }
        // Rotate the processed box
        vector&lt;vector&lt;char&gt;&gt; ans(m, vector&lt;char&gt;(n));
        for (int i = 0; i &lt; n; i++) {
            for (int j = 0; j &lt; m; j++) {
                ans[j][n - 1 - i] = box[i][j];
            }
        }
        return ans;
    }
};</code></pre>
