        <h1>LeetCode 1622: Fancy Sequence (C++)</h1>
        <div class="problem-description">
            <p><strong>Problem:</strong>
                Write an API that generates fancy sequences using the append, addAll, multAll, and getIndex operations.
                append(val) appends an integer val to the sequence. addAll(inc) increments all existing values in the
                sequence by inc. multAll(m) multiplies all existing values in the sequence by m. getIndex(idx) gets the
                current value at index idx (0-indexed) in the sequence, or -1 if the index is out of bounds. All values
                are returned modulo 10^9 + 7.
            </p>
            <p><strong>Example:</strong>
                Input: ["Fancy", "append", "addAll", "append", "multAll", "getIndex", "addAll", "append", "multAll",
                "getIndex", "getIndex", "getIndex"]<br>
                [[], [2], [3], [7], [2], [0], [3], [10], [2], [0], [1], [2]]<br>
                Output: [null, null, null, null, null, 10, null, null, null, 26, 34, 20]<br>
                Explanation: Operations transform the sequence, with results modulo 10^9 + 7.
            </p>
        </div>
        <div class="code-container">
            <button class="copy-button" onclick="copyCode(this)">Copy Code</button>
            <pre><code class="language-cpp">class Fancy {
public:
    static constexpr int MOD = 1e9 + 7;
    vector&lt;unsigned long&gt; arr;
    unsigned long mulFactor = 1;
    unsigned long addFactor = 0;
    void append(int val) {
        // Store original value before current global transform.
        long x = (val - addFactor + MOD) % MOD;
        arr.push_back(x * power(mulFactor, MOD - 2) % MOD);
    }
    void addAll(int inc) {
        addFactor = (addFactor + inc) % MOD;
    }
    void multAll(int m) {
        // Update both multiplier and offset together.
        mulFactor = (mulFactor * m) % MOD;
        addFactor = (addFactor * m) % MOD;
    }
    int getIndex(int idx) {
        if (idx &gt;= arr.size()) return -1;
        return (mulFactor * arr[idx] + addFactor) % MOD;
    }
private:
    long power(long base, long exp) {
        if (exp == 0) return 1;
        if (exp &amp; 1)
            return base * power(base % MOD, exp - 1) % MOD;
        return power(base * base % MOD, exp / 2) % MOD;
    }
};</code></pre>
