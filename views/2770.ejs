    <main>
        <h1>LeetCode 2770: Maximum Number of Jumps to Reach the Last Index (C++)</h1>
        <div class="problem-description">
            <p><strong>Problem:</strong>
                You are given a 0-indexed array nums and an integer target. From index i, you can jump to index j if
                |nums[i] - nums[j]| &lt;= target. Return the maximum number of jumps needed to reach the last index
                starting from index 0. If you cannot reach the last index, return -1.
            </p>
            <p><strong>Example:</strong>
                Input: nums = [1,3,6,4,1,2], target = 2<br>
                Output: 3<br>
                Explanation: One possible path is 0 → 1 → 3 → 5 with 3 jumps. From 1 (value 3), you can jump to 3 (value
                4) since |3-4| = 1 &lt;= 2, and so on.
            </p>
        </div>
        <div class="code-container">
            <button class="copy-button" onclick="copyCode(this)">Copy Code</button>
            <pre><code class="language-cpp">class Solution {
public:
    int maximumJumps(vector&lt;int&gt;&amp; nums, int target) {
        int n = nums.size();
        vector&lt;int&gt; jumps(n, -1);
        jumps[0] = 0;
        for (int end = 1; end &lt; n; end++) {
            for (int start = 0; start &lt; end; start++) {
                // Update answer if current jump is valid
                if (jumps[start] != -1 &amp;&amp;
                    abs(nums[end] - nums[start]) &lt;= target) {
                    jumps[end] = max(jumps[end], jumps[start] + 1);
                }
            }
        }
        return jumps[n - 1];
    }
};</code></pre>
