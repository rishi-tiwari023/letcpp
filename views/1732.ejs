    <main>
        <h1>LeetCode 1732: Find the Highest Altitude (C++)</h1>
        <div class="problem-description">
            <p><strong>Problem:</strong>
                A biker is going on a road trip. The trip consists of n + 1 points at different altitudes. The biker
                starts at point 0 with altitude 0. You are given an integer array gain where gain[i] is the net gain in
                altitude between points i and i + 1. Return the highest altitude of a point.
            </p>
            <p><strong>Example:</strong>
                Input: gain = [-5,1,5,0,-7]<br>
                Output: 1<br>
                Explanation: Altitudes are [0,-5,-4,1,1,-6]. The highest altitude is 1.
            </p>
        </div>
        <div class="code-container">
            <button class="copy-button" onclick="copyCode(this)">Copy Code</button>
            <pre><code class="language-cpp">class Solution {
public:
    int largestAltitude(vector&lt;int&gt;&amp; gain) {
        int highestAltitude = 0, currentAltitude = 0;
        for (int change : gain) {
            currentAltitude += change; // Update altitude after this segment
            highestAltitude = max(highestAltitude, currentAltitude);
        }
        return highestAltitude;
    }
};</code></pre>
