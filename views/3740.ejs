        <h1>LeetCode 3740: Minimum Distance Between Three Equal Elements I (C++)</h1>
        <div class="problem-description">
            <p><strong>Problem:</strong>
                You are given an array nums. Find the minimum distance (sum of absolute differences) between any three
                equal elements in the array. The distance is calculated as the sum of absolute differences between their
                indices. If no three equal elements exist, return -1.
            </p>
            <p><strong>Example:</strong>
                Input: nums = [1,2,1,1,2,1]<br>
                Output: 2<br>
                Explanation: The element 1 appears at indices [0,2,3,5]. The minimum distance among any three
                occurrences is |2-3| + |3-0| + |2-0| = 1 + 3 + 2 = 2 (or other valid combinations).
            </p>
        </div>
        <div class="code-container">
            <button class="copy-button" onclick="copyCode(this)">Copy Code</button>
            <pre><code class="language-cpp">class Solution {
public:
    // Computes minimum distance for one value's indices
    int computeMinDistance(vector&lt;int&gt;&amp; indices) {
        int best = INT_MAX;
        // Sliding window of size 3
        for (int i = 2; i &lt; indices.size(); i++) {
            best = min(best,
                abs(indices[i] - indices[i - 1]) +
                abs(indices[i - 1] - indices[i - 2]) +
                abs(indices[i] - indices[i - 2])
            );
        }
        return best;
    }
    int minimumDistance(vector&lt;int&gt;&amp; nums) {
        unordered_map&lt;int, vector&lt;int&gt;&gt; indexMap;
        // Group indices by value
        for (int i = 0; i &lt; nums.size(); i++) {
            indexMap[nums[i]].push_back(i);
        }
        int ans = INT_MAX;
        for (auto &amp;entry : indexMap) {
            vector&lt;int&gt; &amp;indices = entry.second;
            if (indices.size() &gt;= 3) {
                ans = min(ans, computeMinDistance(indices));
            }
        }
        return (ans == INT_MAX) ? -1 : ans;
    }
};</code></pre>
