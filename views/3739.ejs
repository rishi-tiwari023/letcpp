        <h1>LeetCode 3739: Count Subarrays With Majority Element II (C++)</h1>
        <div class="problem-description">
            <p><strong>Problem:</strong>
                You are given an integer array nums and an integer target. Return the number of subarrays where target is the majority element. A majority element of a subarray is an element that appears strictly more than half the length of the subarray.
            </p>
            <p><strong>Example:</strong>
                Input: nums = [1,2,1,1,2], target = 1<br>
                Output: 9<br>
                Explanation: Count all subarrays where 1 appears strictly more than half the time. Single elements [1] (3 of them), plus several multi-element subarrays, totalling 9 valid subarrays.
            </p>
        </div>
        <div class="code-container">
            <button class="copy-button" onclick="copyCode(this)">Copy Code</button>
            <pre><code class="language-cpp">class Solution {
public:
    long long countMajoritySubarrays(vector&lt;int&gt;&amp; nums, int target) {
        int len = nums.size();
        vector&lt;int&gt; count(2 * len + 1, 0);
        int pos = len;
        count[pos] = 1;
        long long ans = 0;
        long long curr = 0;
        for (int val : nums) {
            if (val == target) {
                curr += count[pos];
                pos++;
            } else {
                pos--;
                curr -= count[pos];
            }
            // Record the current balance.
            count[pos]++;
            ans += curr;
        }
        return ans;
    }
};</code></pre>
