<body>
    <main>
        <h1>LeetCode 3161: Block Placement Queries (C++)</h1>
        <div class="problem-description">
            <p><strong>Problem:</strong> You are given an infinite number line starting at 0 and extending towards the positive x-axis. You need to process a sequence of queries, which are of two types:</p>
            <ul>
                <li><strong>Type 1 (<code>[1, x]</code>):</strong> Build an obstacle at distance <code>x</code> from the origin. It is guaranteed that no obstacle currently exists at <code>x</code>.</li>
                <li><strong>Type 2 (<code>[2, x, sz]</code>):</strong> Check if it is possible to place a block of size <code>sz</code> anywhere in the range <code>[0, x]</code>. The block must lie entirely within <code>[0, x]</code>, and cannot intersect with any obstacle (though it may touch one). This query does not actually place a block; it only checks for feasibility.</li>
            </ul>
            <p>You must return a boolean array containing the results for all queries of type 2.</p>
        </div>
        <div class="code-container">
            <button class="copy-button" onclick="copyCode(this)">Copy Code</button>
            <pre><code class="language-cpp">class Solution {
public:
    vector&lt;bool&gt; getResults(vector&lt;vector&lt;int&gt;&gt;&amp; queries) {
        set&lt;int&gt; walls;
        walls.insert(0);
        walls.insert(100000);

        map&lt;int, set&lt;int&gt;&gt; gaps;
        gaps[100000].insert(100000);

        vector&lt;bool&gt; res;

        for (auto &amp;qry : queries) {
            if (qry[0] == 1) {
                int pos = qry[1];

                int leftWall = *(--walls.lower_bound(pos));
                int rightWall = *(walls.lower_bound(pos));

                gaps[rightWall - leftWall].erase(rightWall);

                if (gaps[rightWall - leftWall].empty())
                    gaps.erase(rightWall - leftWall);

                gaps[rightWall - pos].insert(rightWall);
                gaps[pos - leftWall].insert(pos);

                walls.insert(pos);
            }
            else {
                int limit = qry[1];
                int len = qry[2];

                bool possible = false;

                auto it = gaps.lower_bound(len);

                while (it != gaps.end()) {
                    int rightEnd = *it-&gt;second.begin();

                    if (rightEnd &lt;= limit) {
                        possible = true;
                        break;
                    }
                    else {
                        int leftWall = *(--walls.lower_bound(limit));

                        // Check the partial segment containing limit
                        if (limit - leftWall &gt;= len) {
                            possible = true;
                            break;
                        }
                    }
                    ++it;
                }

                res.push_back(possible);
            }
        }

        return res;
    }
};</code></pre>
