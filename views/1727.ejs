    <main>
        <h1>LeetCode 1727: Largest Submatrix With Rearrangements (C++)</h1>
        <div class="problem-description">
            <p><strong>Problem:</strong>
                You are given a binary matrix matrix of size m x n, and you are allowed to rearrange the columns of the
                matrix in any order. Return the area of the largest submatrix within matrix where every element of the
                submatrix is 1 after reordering the columns optimally.
            </p>
            <p><strong>Example:</strong>
                Input: matrix = [[0,0,1],[1,1,1],[1,0,1]]<br>
                Output: 4<br>
                Explanation: You can rearrange the columns as shown to get a submatrix of all 1s with area 4 (2 rows x 2
                columns).
            </p>
        </div>
        <div class="code-container">
            <button class="copy-button" onclick="copyCode(this)">Copy Code</button>
            <pre><code class="language-cpp">class Solution {
public:
    int largestSubmatrix(vector&lt;vector&lt;int&gt;&gt;&amp; matrix) {
        int rowCount = matrix.size();
        int colCount = matrix[0].size();
        vector&lt;vector&lt;int&gt;&gt; heights(rowCount, vector&lt;int&gt;(colCount, 0));
        for (int col = 0; col &lt; colCount; col++) {
            heights[0][col] = matrix[0][col];
        }
        // Build histogram heights row by row
        for (int row = 1; row &lt; rowCount; row++) {
            for (int col = 0; col &lt; colCount; col++) {
                if (matrix[row][col] == 1) {
                    heights[row][col] = heights[row - 1][col] + 1;
                }
            }
        }
        int answer = 0;
        for (int row = 0; row &lt; rowCount; row++) {
            vector&lt;int&gt; currRow = heights[row];
            sort(currRow.begin(), currRow.end(), greater&lt;int&gt;());
            for (int col = 0; col &lt; colCount; col++) {
                int width = col + 1;
                answer = max(answer, currRow[col] * width);
            }
        }
        return answer;
    }
};</code></pre>
