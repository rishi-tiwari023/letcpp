        <h1>LeetCode 1848: Minimum Distance to the Target Element (C++)</h1>
        <div class="problem-description">
            <p><strong>Problem:</strong>
                You are given an array arr, a target value, and a starting index. Find the minimum distance from the
                starting index to any element in the array that equals the target value. The distance is measured as the
                absolute difference between indices.
            </p>
            <p><strong>Example:</strong>
                Input: arr = [5,1,1,1,1], targetVal = 1, startIdx = 3<br>
                Output: 0<br>
                Explanation: arr[3] = 1 which equals the target, so the minimum distance is 0.
            </p>
        </div>
        <div class="code-container">
            <button class="copy-button" onclick="copyCode(this)">Copy Code</button>
            <pre><code class="language-cpp">class Solution {
public:
    int getMinDistance(vector&lt;int&gt;&amp; arr, int targetVal, int startIdx) {
        int n = arr.size();
        // expand distance step-by-step from start index
        for(int dist = 0; dist &lt; n; dist++){
            
            // check left side first
            if(startIdx - dist &gt;= 0 &amp;&amp; arr[startIdx - dist] == targetVal)
                return dist;
            // then check right side
            if(startIdx + dist &lt; n &amp;&amp; arr[startIdx + dist] == targetVal)
                return dist;
        }
        return -1; // fallback (though problem guarantees target exists)
    }
};</code></pre>
