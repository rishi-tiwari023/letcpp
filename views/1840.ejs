    <main>
        <h1>LeetCode 1840: Maximum Building Height (C++)</h1>
        <div class="problem-description">
            <p><strong>Problem:</strong>
                You want to build n buildings in a line. The height of the i-th building must be a non-negative integer,
                and building 1 must have height 0. The height difference between adjacent buildings must be at most 1.
                You are given an array of restrictions where restrictions[i] = [id, maxHeight] means building id cannot
                exceed maxHeight. Return the maximum possible height of the tallest building.
            </p>
            <p><strong>Example:</strong>
                Input: n = 5, restrictions = [[2,1],[4,1]]<br>
                Output: 2<br>
                Explanation: The optimal heights are [0,1,2,1,2], giving a maximum height of 2.
            </p>
        </div>
        <div class="code-container">
            <button class="copy-button" onclick="copyCode(this)">Copy Code</button>
            <pre><code class="language-cpp">class Solution {
public:
    int maxBuilding(int n, vector&lt;vector&lt;int&gt;&gt;&amp; restrictions) {
        restrictions.push_back({1, 0});
        restrictions.push_back({n, n - 1});
        sort(restrictions.begin(), restrictions.end());
        // Tighten restrictions using the left neighbor.
        for (int i = 1; i &lt; restrictions.size(); i++) {
            int gap = restrictions[i][0] - restrictions[i - 1][0];
            restrictions[i][1] =
                min(restrictions[i][1],
                    restrictions[i - 1][1] + gap);
        }
        // Tighten restrictions using the right neighbor.
        for (int i = (int)restrictions.size() - 2; i &gt;= 0; i--) {
            int gap = restrictions[i + 1][0] - restrictions[i][0];
            restrictions[i][1] =
                min(restrictions[i][1],
                    restrictions[i + 1][1] + gap);
        }
        int answer = 0;
        for (int i = 1; i &lt; restrictions.size(); i++) {
            long long leftId = restrictions[i - 1][0];
            long long leftHeight = restrictions[i - 1][1];
            long long rightId = restrictions[i][0];
            long long rightHeight = restrictions[i][1];
            long long gap = rightId - leftId;
            long long maxPeak =
                (leftHeight + rightHeight + gap) / 2;
            answer = max(answer, (int)maxPeak);
        }
        return answer;
    }
};</code></pre>
