        <h1>LeetCode 2784: Check if Array is Good (C++)</h1>
        <div class="problem-description">
            <p><strong>Problem:</strong>
                An array with n elements is "good" if it contains the elements [1, 2, ..., n-1, n-1] in some order.
                Given an array arr, determine if it is good.
            </p>
            <p><strong>Example:</strong>
                Input: arr = [1,3,4,4,1]<br>
                Output: false<br>
                Explanation: The array has length 5, so a good array should contain [1,2,3,4,4]. The input has
                [1,3,4,4,1] which doesn't match because it's missing 2 and has an extra 1.
            </p>
        </div>
        <div class="code-container">
            <button class="copy-button" onclick="copyCode(this)">Copy Code</button>
            <pre><code class="language-cpp">class Solution {
public:
    bool isGood(vector&lt;int&gt;&amp; arr) {
        int size = arr.size();
        unordered_map&lt;int, int&gt; freq;
        // Build expected frequency map
        for (int num = 1; num &lt; size; num++) {
            freq[num]++;
        }
        freq[size - 1]++;
        for (int val : arr) {
            if (freq[val] &gt; 0) {
                freq[val]--;
            } 
            else {
                return false;
            }
        }
        return true;
    }
};</code></pre>
