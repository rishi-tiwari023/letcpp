    <main>
        <h1>LeetCode 3499: Maximize Active Section with Trade I (C++)</h1>
        <div class="problem-description">
            <p><strong>Problem:</strong>
                You are given a binary string s. You may perform at most one trade: pick a maximal block of consecutive
                '0's and flip it to '1's, but as a cost you must flip an equal number of adjacent '1's back to '0's on
                one side, effectively swapping the boundary. Return the maximum number of active ('1') sections
                achievable.
            </p>
            <p><strong>Example:</strong>
                Input: s = "01101"<br>
                Output: 4<br>
                Explanation: The runs are [-1,+2,-1,+1]. Trading the middle zero run of length 1 (between the two
                positive runs is not directly adjacent here), evaluating valid [-,+,-] patterns yields the maximum
                active count of 4.
            </p>
        </div>
        <div class="code-container">
            <button class="copy-button" onclick="copyCode(this)">Copy Code</button>
            <pre><code class="language-cpp">class Solution {
public:
    int maxActiveSectionsAfterTrade(string s) {
        vector&lt;int&gt; runs;
        int n = s.size();
        int segmentValue = 0;
        int totalOnes = 0;
        int answer = 0;
        // Store each run as +length (1's) or -length (0's).
        for (int i = 0; i &lt; n; i++) {
            if (i &amp;&amp; s[i] != s[i - 1]) {
                runs.push_back(segmentValue);
                segmentValue = 0;
            }
            segmentValue += (s[i] == '1' ? 1 : -1);
        }
        runs.push_back(segmentValue);
        for (int val : runs)
            if (val &gt; 0)
                totalOnes += val;
        answer = totalOnes;
        // Trade only helps for a [-,+,-] pattern.
        for (int i = 1; i + 1 &lt; runs.size(); i++) {
            if (runs[i - 1] &lt; 0 &amp;&amp; runs[i] &gt; 0 &amp;&amp; runs[i + 1] &lt; 0) {
                answer = max(answer,
                             totalOnes + abs(runs[i - 1] + runs[i + 1]));
            }
        }
        return answer;
    }
};</code></pre>
