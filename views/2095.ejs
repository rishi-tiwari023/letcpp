        <h1>LeetCode 2095: Delete the Middle Node of a Linked List (C++)</h1>
        <div class="problem-description">
            <p><strong>Problem:</strong>
                You are given the head of a linked list. Delete the middle node of the linked list and return the head
                of the modified list. The middle node of a linked list of length n is the node at position floor(n/2)
                from the start using 0-based indexing.
            </p>
            <p><strong>Example:</strong>
                Input: head = [1,3,4,2]<br>
                Output: [1,4,2]<br>
                Explanation: The middle node is the node with value 3 (at index 1). After deleting it, the list becomes
                [1,4,2].
            </p>
        </div>
        <div class="code-container">
            <button class="copy-button" onclick="copyCode(this)">Copy Code</button>
            <pre><code class="language-cpp">class Solution {
public:
    ListNode* deleteMiddle(ListNode* head) {
        if (!head-&gt;next) return nullptr;
        ListNode *midPrev = head, *runner = head-&gt;next;
        // Find node just before the middle node
        while (runner-&gt;next &amp;&amp; runner-&gt;next-&gt;next) {
            runner = runner-&gt;next-&gt;next;
            midPrev = midPrev-&gt;next;
        }
        midPrev-&gt;next = midPrev-&gt;next-&gt;next; // Remove middle node
        return head;
    }
};</code></pre>
