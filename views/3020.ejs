        <h1>LeetCode 3020: Find the Maximum Number of Elements in Subset (C++)</h1>
        <div class="problem-description">
            <p><strong>Problem:</strong>
                You are given an array nums of positive integers. You need to find the maximum length of a subset where
                elements can be arranged as [x, x^2, x^4, ..., x^(2^k), ..., x^4, x^2, x] — a palindrome-like sequence
                of powers of x. Return the maximum length of such a subset.
            </p>
            <p><strong>Example:</strong>
                Input: nums = [5,4,1,2,2,4,1,5,1]<br>
                Output: 7<br>
                Explanation: Subset [1,4,2,1,2,4,1] forms a valid sequence where 1 appears 3 times (odd), and 4 and 2
                appear twice each, giving length 7.
            </p>
        </div>
        <div class="code-container">
            <button class="copy-button" onclick="copyCode(this)">Copy Code</button>
            <pre><code class="language-cpp">class Solution {
public:
    int maximumLength(vector&lt;int&gt;&amp; nums) {
        unordered_map&lt;long long, long long&gt; freq;
        for (int num : nums) {
            freq[num]++;
        }
        long long answer = 0;
        for (auto &amp;entry : freq) {
            long long value = entry.first;
            if (value == 1) {
                answer = max(answer, (freq[1] % 2 == 0) ? freq[1] - 1 : freq[1]);
                continue;
            }
            long long chainLen = 0;
            // Move through the square sequence while pairs are available.
            while (freq.count(value) &amp;&amp; freq[value] &gt;= 2) {
                chainLen += 2;
                value *= value;
            }
            if (freq.count(value) &amp;&amp; freq[value] == 1)
                chainLen++;
            else
                chainLen--;
            answer = max(answer, chainLen);
        }
        return answer;
    }
};</code></pre>
