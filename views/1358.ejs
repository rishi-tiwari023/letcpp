    <main>
        <h1>LeetCode 1358: Number of Substrings Containing All Three Characters (C++)</h1>
        <div class="problem-description">
            <p><strong>Problem:</strong>
                Given a string s consisting only of characters 'a', 'b', and 'c', return the number of substrings that
                contain at least one occurrence of all three characters a, b, and c.
            </p>
            <p><strong>Example:</strong>
                Input: s = "abcabc"<br>
                Output: 10<br>
                Explanation: The substrings containing all three characters are "abc", "abca", "abcab", "abcabc", "bca",
                "bcab", "bcabc", "cab", "cabc" and "abc". The total count is 10.
            </p>
        </div>
        <div class="code-container">
            <button class="copy-button" onclick="copyCode(this)">Copy Code</button>
            <pre><code class="language-cpp">class Solution {
public:
    int numberOfSubstrings(string s) {
        return countValidSubstrings(s);
    }
private:
    int countValidSubstrings(const string&amp; str) {
        int n = str.size();
        int answer = 0;
        int lastSeen[3] = {-1, -1, -1};
        for (int i = 0; i &lt; n; i++) {
            int ch = str[i] - 'a';
            lastSeen[ch] = i;
            // Compute the other two character indices.
            int first = ch + 1 - (-(ch == 2) &amp; 3);
            int second = ch + 2 - (-(ch &gt;= 1) &amp; 3);
            answer += min(lastSeen[first], lastSeen[second]) + 1;
        }
        return answer;
    }
};</code></pre>
